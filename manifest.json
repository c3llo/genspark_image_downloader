{
    "manifest_version": 3,
    "name": "AI Asset Master Collector",
    "version": "1.6",
    "permissions": ["storage", "downloads", "activeTab"],
    "host_permissions": [
        "https://*.genspark.ai/*",
        "https://labs.google/*",
        "<all_urls>"
    ],
    "action": { "default_popup": "popup.html" },
    "content_scripts": [
        {
            "matches": [
                "https://*.genspark.ai/*",
                "https://labs.google/*"
            ],
            "js": ["content.js"],
            "all_frames": true,
            "run_at": "document_idle"
        }
    ]
}